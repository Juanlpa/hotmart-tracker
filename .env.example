# ============================================================
# HOTMART TRACKER — Variables de Entorno
# ============================================================
# INSTRUCCIONES:
# 1. Copiar este archivo como .env:  copy .env.example .env
# 2. Llenar cada valor siguiendo la guía en SETUP_GUIDE.md
# 3. NUNCA subir .env a GitHub (ya está en .gitignore)
# ============================================================

# --- Supabase (PASO 1 de la guía) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# --- Telegram Bot (PASO 2 de la guía) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- YouTube Data API v3 (PASO 3 de la guía) ---
YT_API_KEY=your_youtube_api_key

# --- Facebook Ad Library API (PASO 4 de la guía) ---
FB_ACCESS_TOKEN=your_facebook_access_token
# --- Configuración del pipeline ---
TARGET_MARKET=BR
SCORE_ALERT_THRESHOLD=65
MIN_COMMISSION_PCT=60
MIN_RATING=4.0
SCRAPER_DELAY_MIN=3
SCRAPER_DELAY_MAX=7

# --- Pesos de scoring (recalibrar tras backtesting, deben sumar 1.0) ---
WEIGHT_HOTMART=0.25
WEIGHT_FB=0.35
WEIGHT_TRENDS=0.25
WEIGHT_YOUTUBE=0.15

# --- Hotmart Login (para comisión y temperatura) ---
HOTMART_EMAIL=
HOTMART_PASSWORD=

# --- Opcional: Proxy para scraper ---
HOTMART_SCRAPER_PROXY=
